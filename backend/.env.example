# Comma-separated list of allowed origins (e.g., https://your-portfolio.vercel.app)
ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000

# Resend API Key for email notifications (Get one at resend.com)
RESEND_API_KEY=re_123456789

# Verified email address for sending contact notifications
PORTFOLIO_EMAIL_FROM=contact@yourdomain.com
